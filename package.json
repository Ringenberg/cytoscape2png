{
  "name": "cytoscape2png",
  "version": "1.0.5",
  "description": "Command line tool for converting a Cytograph json file to a png image.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "cytoscape2png": "index.js"
  },
  "scripts": {
    "test": "ava",
    "lint": "eslint index.js",
    "precommit": "npm test && npm run lint && prettier -c index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ringenberg/cytoscape2png.git"
  },
  "keywords": [
    "cytoscape",
    "png"
  ],
  "author": {
    "name": "Michael Ringenberg",
    "email": "Ringenberg@users.noreply.github.com",
    "url": "https://ringenberg.github.io/"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ringenberg/cytoscape2png/issues"
  },
  "homepage": "https://github.com/Ringenberg/cytoscape2png#readme",
  "dependencies": {
    "commander": "^15.0.0",
    "cytoscape": "^3.34.0",
    "puppeteer": "^25.2.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "ava": "^8.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "looks-same": "^10.0.1",
    "prettier": "^3.9.4",
    "tap-xunit": "^2.4.1"
  },
  "allowScripts": {
    "puppeteer@25.2.1": true
  }
}
